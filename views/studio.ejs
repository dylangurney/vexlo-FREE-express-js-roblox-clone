          const propnode = document.createElement("div")
          propnode.className = "propnode";

          propnode.innerHTML = htmlitem



          propstree.appendChild(propnode)
          return propnode
        }



        for (const name of Object.keys(props)) {
          const v = props[name]

          const proptype = prop_types[name]


          if (proptype == "String") {

            let disabled = props_readonly.includes(name);

