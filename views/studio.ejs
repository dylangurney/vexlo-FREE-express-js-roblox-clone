              <div class="propitem ${disabled ? "readonly" : ""}">
                <span class="propname">${escapeHTML(name)}</span>
                <input class="propvalue" value="${escapeHTML(v)}" placeholder="Enter a String.." ${disabled ? "readonly" : ""}>
              </div>
            `;

            let propnode = dostuffwithit(htmlitem);

            let input = propnode.querySelector(".propvalue");

            input.addEventListener("blur", () => {
              let newv = input.value.toString()

              if (newv) {
                window.GAMEMODEL[ID].props[name] = newv
                window.IS_DIRTY = true
              }

              update_properties_tab(selectedNode.id)
              update_explorer()

              UpdateOBJ_asrendered(ID)
            });


          } else if (proptype == "Number") {

            let disabled = props_readonly.includes(name);

            let htmlitem = `
              <div class="propitem ${disabled ? "readonly" : ""}">
                <span class="propname">${escapeHTML(name)}</span>
                <input class="propvalue" value="${escapeHTML(v)}" placeholder="Enter a Number.." ${disabled ? "readonly" : ""}>
              </div>
            `;

            let propnode = dostuffwithit(htmlitem);

            let input = propnode.querySelector(".propvalue");

            input.addEventListener("blur", () => {
              let newv = parseInt(input.value, 10)

              if (newv) {
                window.GAMEMODEL[ID].props[name] = newv
                window.IS_DIRTY = true
              }

              update_properties_tab(selectedNode.id)
              update_explorer()
              UpdateOBJ_asrendered(ID)
            });


          } else if (proptype == "Object") {


            let objname = ""

            if (props[name] && window.GAMEMODEL[props[name]]) {
              objname = window.GAMEMODEL[props[name]].props["Name"]
            }

            let disabled = (v === GAME_MODEL_ID);

            let htmlitem = `
              <div class="propitem">
                <span class="propname">${escapeHTML(name)}</span>
                <button class="propvalueobjectbtn" ${disabled ? "disabled" : ""}>${escapeHTML(objname)}</button>

                <button class="propvalueobjectbtnNULL">
                  <img src="/cross.svg" class="btnnullic whiteimg">
                  </button>
              </div>`
            let propnode = dostuffwithit(htmlitem)

            propnode.querySelector(".propvalueobjectbtn").onclick = function () {
              if (window.obj_prop_changing) {
                document.body.classList.remove("pickmode");

                propnode.querySelector(".propvalueobjectbtn").disabled = false
                window.obj_prop_changing = false
              } else {
                window.obj_prop_changing = { ID, name }
                document.body.classList.add("pickmode");
                propnode.querySelector(".propvalueobjectbtn").disabled = true
              }
            }

            propnode.querySelector(".propvalueobjectbtnNULL").onclick = function () {
                window.GAMEMODEL[ID].props[name] = null;
                window.IS_DIRTY = true

                update_properties_tab(selectedNode.id);
                update_explorer();
                UpdateOBJ_asrendered(ID)
            }

          } else if (proptype == "Vector3") {

            let disabled = props_readonly.includes(name);

            let visibleVector3 = Object.values(v).join(", ");

            let htmlitem = `
              <div class="propitem ${disabled ? "readonly" : ""}">
                <span class="propname">${escapeHTML(name)}</span>
                <input class="propvalue" value="${escapeHTML(visibleVector3)}" placeholder="Enter a Vector 3.." ${disabled ? "readonly" : ""}>
              </div>
            `;

            let propnode = dostuffwithit(htmlitem);

            let input = propnode.querySelector(".propvalue");

            input.addEventListener("blur", () => {

              let raw = input.value;

              // detect vector3 format
              if (raw.includes(",")) {

                let parts = raw.split(",").map(v => parseFloat(v.trim()));

                if (parts.length === 3 && parts.every(n => !isNaN(n))) {
                  window.GAMEMODEL[ID].props[name] = {
                    x: parts[0],
                    y: parts[1],
                    z: parts[2]
                  };
                  window.IS_DIRTY = true
                }

              } else {

                let newv = parseFloat(raw);

                if (!isNaN(newv)) {
                  window.GAMEMODEL[ID].props[name] = newv;
                  window.IS_DIRTY = true
                }
              }

              update_properties_tab(selectedNode.id);
              update_explorer();
              UpdateOBJ_asrendered(ID)
            });


          } else if (proptype == "Vector2") {

            let disabled = props_readonly.includes(name);

            let visibleVector3 = Object.values(v).join(", ");

            let htmlitem = `
              <div class="propitem ${disabled ? "readonly" : ""}">
                <span class="propname">${escapeHTML(name)}</span>
                <input class="propvalue" value="${escapeHTML(visibleVector3)}" placeholder="Enter a Vector 2.." ${disabled ? "readonly" : ""}>
              </div>
            `;

            let propnode = dostuffwithit(htmlitem);

            let input = propnode.querySelector(".propvalue");

            input.addEventListener("blur", () => {

              let raw = input.value;

              // detect vector3 format
              if (raw.includes(",")) {

                let parts = raw.split(",").map(v => parseFloat(v.trim()));

                if (parts.length === 2 && parts.every(n => !isNaN(n))) {
                  window.GAMEMODEL[ID].props[name] = {
                    x: parts[0],
                    y: parts[1]
                  };
                  window.IS_DIRTY = true
                }

              } else {

                let newv = parseFloat(raw);

                if (!isNaN(newv)) {
                  window.GAMEMODEL[ID].props[name] = newv;
                  window.IS_DIRTY = true
                }
              }

              update_properties_tab(selectedNode.id);
              update_explorer();
              UpdateOBJ_asrendered(ID)
            });


          } else if (proptype == "Color3") {

            let disabled = props_readonly.includes(name);

            let visibleVector3 = Object.values(v).join(", ");

            let htmlitem = `
              <div class="propitem ${disabled ? "readonly" : ""}">
                <span class="propname">${escapeHTML(name)}</span>
                <input class="propvalue" value="${escapeHTML(visibleVector3)}" placeholder="Enter a Vector 2.." ${disabled ? "readonly" : ""}>
              </div>
            `;

            let propnode = dostuffwithit(htmlitem);

            let input = propnode.querySelector(".propvalue");

            input.addEventListener("blur", () => {

              let raw = input.value;

              // detect vector3 format
              if (raw.includes(",")) {

                let parts = raw.split(",").map(v => parseFloat(v.trim()));

                if (parts.length === 3 && parts.every(n => !isNaN(n))) {
                  window.GAMEMODEL[ID].props[name] = {
                    r: parts[0],
                    g: parts[1],
                    b: parts[2],
                  };
                  window.IS_DIRTY = true
                }

              } else {

                let newv = parseFloat(raw);

                if (!isNaN(newv)) {
                  window.GAMEMODEL[ID].props[name] = newv;
                  window.IS_DIRTY = true
                }
              }

              update_properties_tab(selectedNode.id);
              update_explorer();
              UpdateOBJ_asrendered(ID)
            });

          } else if (proptype == "Bool") {

            let disabled = props_readonly.includes(name);

            let htmlitem = `
              <div class="propitem ${disabled ? "readonly" : ""}">
                <span class="propname">${escapeHTML(name)}</span>

                <input 
                  class="propvalue-bool" 
                  type="checkbox" 
                  ${v ? "checked" : ""} 
                  ${disabled ? "disabled" : ""}
                >
              </div>
            `;

            let propnode = dostuffwithit(htmlitem);
            let checkbox = propnode.querySelector(".propvalue-bool");

            checkbox.addEventListener("change", () => {
              window.GAMEMODEL[ID].props[name] = checkbox.checked
              window.IS_DIRTY = true


              update_properties_tab(selectedNode.id)
              update_explorer()
              UpdateOBJ_asrendered(ID)
            });

          } else if (proptype == "CFrame") {

            let disabled = props_readonly.includes(name);

            let cf = v

            let posValue = escapeHTML(`${cf.position.x}, ${cf.position.y}, ${cf.position.z}`);
            let rotValue = escapeHTML(`${cf.rotation.x}, ${cf.rotation.y}, ${cf.rotation.z}`);

            let htmlitem = `
              <div class="propitem ${disabled ? "readonly" : ""}">
                <span class="propname">${escapeHTML(name)}</span>

                <div class="cframe-editor">

                  <div class="cframe-row">
                    <span class="propname">Pos</span>
                    <input class="cf-pos propvalue"
                      value="${posValue}"
                      ${disabled ? "readonly" : ""}>
                  </div>

                  <div class="cframe-row">
                    <span class="propname">Rot</span>
                    <input class="cf-rot propvalue"
                      value="${rotValue}"
                      ${disabled ? "readonly" : ""}>
                  </div>

                </div>
              </div>
            `;

            let propnode = dostuffwithit(htmlitem);

              let posInput = propnode.querySelector(".cf-pos");
              let rotInput = propnode.querySelector(".cf-rot");

              function parseVec3(str) {
                let parts = str.split(",").map(v => parseFloat(v.trim()));
                if (parts.length !== 3 || parts.some(n => isNaN(n))) return null;
                return { x: parts[0], y: parts[1], z: parts[2] };
              }

              function applyCFrameUpdate() {
                let pos = parseVec3(posInput.value);
                let rot = parseVec3(rotInput.value);

                if (!pos || !rot) return;

                window.GAMEMODEL[ID].props[name] = {
                  position: pos,
                  rotation: rot
                };

                window.IS_DIRTY = true;

                update_properties_tab(selectedNode.id);
                update_explorer();
                UpdateOBJ_asrendered(ID);
              }

              posInput.addEventListener("blur", applyCFrameUpdate);
              rotInput.addEventListener("blur", applyCFrameUpdate);




          } else  {
            console.log(v)
          }
        
      

          //next
        }

        let htmlitem2 = `
              <div class="propitem ${true ? "readonly" : ""}">
                <span class="propname">${escapeHTML("Instance ID")}</span>
                <input class="propvalue" value="${escapeHTML(ID)}" placeholder="" ${true ? "readonly" : ""}>
              </div>
            `;

        let propnode = dostuffwithit(htmlitem2);

      }
    


      window.update_properties_tab = update_properties_tab
      async function Create_vexl(GAMEMODEL) {
        const json = JSON.stringify(GAMEMODEL);
        const encoder = new TextEncoder();
        const data = encoder.encode(json);
        const cs = new CompressionStream("gzip");
        const writer = cs.writable.getWriter();
        writer.write(data);
        writer.close();
        const compressed = await new Response(cs.readable).arrayBuffer();
        return compressed; // ArrayBuffer
      }
      window.Create_vexl = Create_vexl

      document.getElementById("savevex").onclick = async function () {
        const vexl = await Create_vexl(window.GAMEMODEL);

        // turn into a file
        const blob = new Blob([vexl], { type: "application/gzip" });

        const url = URL.createObjectURL(blob);

        const a = document.createElement("a");
        a.href = url;
        a.download = "game.vexl"; // filename
        a.click();

        URL.revokeObjectURL(url);
      };

