      document.getElementById("publishPopup").classList.add("hidden");
      document.getElementById("pub1").classList.add("hidden");
      document.getElementById("pub2").classList.add("hidden");
      document.getElementById("pub3").classList.add("hidden");
      setLoading(0, "");
    }


  window.CURRENT_UPLOAD = null;
    document.getElementById("cancelpublishrunning").oncancel = async function () {
      window.CURRENT_UPLOAD.abort()
      document.getElementById("publishPopup").classList.add("hidden");
    }

    let saving = false;

    setInterval(async () => {
      if (saving) return;
      if (!window.IS_DIRTY) return;
          const editingid = window.EDITING_ID;
      saving = true;
      COOLoutput(0, "Auto Saving...", "", "")

      const vexlbuff = await Create_vexl(window.GAMEMODEL);

      await fetch(`/api/studio/save/${editingid}`, {
        method: "POST",
        headers: { "Content-Type": "application/octet-stream" },
        body: vexlbuff
      });
      window.IS_DIRTY = false
      COOLoutput(0, "Saved...", "", "")

      saving = false;
    }, 5000);


  document.getElementById("confirmPublish").onclick = async function () {
    document.getElementById("pub1").classList.add("hidden");
    document.getElementById("pub2").classList.remove("hidden");

    setLoading(1, "Creating .vexl ...");

    const vexlbuff = await Create_vexl(window.GAMEMODEL);
    const editingid = window.EDITING_ID;

    setLoading(5, "Uploading...");

    const xhr = new XMLHttpRequest();
    window.CURRENT_UPLOAD = xhr;

    xhr.open("POST", `/api/studio/publish/${editingid}`);

    xhr.setRequestHeader("Content-Type", "application/octet-stream");
    xhr.setRequestHeader("x-game-id", editingid);

    // 🔥 upload progress
    xhr.upload.onprogress = (e) => {
      if (e.lengthComputable) {
        const percent = Math.floor((e.loaded / e.total) * 100);
        setLoading(percent, `Uploading... ${percent}%`);
      }
    };

    xhr.onload = () => {
      if (xhr.status === 200) {
        setLoading(100, "Done!");
        document.querySelector(".donebtn").classList.remove("hidden");
      } else {
        setLoading(0, "Upload failed");
      }
    };

    xhr.onerror = () => {
      setLoading(0, "Network error");
    };

    xhr.send(vexlbuff);
  };

      document.getElementById("loadvex").onclick = async function () {
        const input = document.createElement("input");
        input.type = "file";
        input.accept = ".vexl";

        input.onchange = async () => {
          const file = input.files[0];
          if (!file) return;

          const buffer = await file.arrayBuffer();


          await LOADVEXL_FROM_ARRAY_BUFFER(buffer)

        };

        input.click();
      };



      function handle_parent_change(OBJECT, PARENT) {
        const oldParent = window.GAMEMODEL[OBJECT].props["Parent"];

        // Remove from old parent's children
        if (oldParent && window.GAMEMODEL[oldParent]) {
          const siblings = window.GAMEMODEL[oldParent].children;
          const index = siblings.indexOf(OBJECT);
          if (index !== -1) {
            siblings.splice(index, 1);
          }
        }

        // Set new parent
        window.GAMEMODEL[OBJECT].props["Parent"] = PARENT;


        // Add to new parent's children
        if (PARENT && window.GAMEMODEL[PARENT]) {
          window.GAMEMODEL[PARENT].children.push(OBJECT);
        }

        if (oldParent) {
          UpdateOBJ_asrendered(oldParent)
        }


        UpdateOBJ_asrendered(PARENT)

        window.IS_DIRTY = true

        update_explorer()
        update_properties_tab(selectedNode.id)
      }
      window.handle_parent_change = handle_parent_change

      function handle_delete_obj(OBJECT, not_main) {
        const thatdata = window.GAMEMODEL[OBJECT]
        if (thatdata.props.Parent == GAME_MODEL_ID) {
          return
        }

        const children = thatdata["children"]
        for (const i of children) {
          handle_delete_obj(i, true)
        }

        let rendered = ID_TO_MESH[OBJECT]
        if (rendered) {
          window.scene.remove(rendered);
          delete ID_TO_MESH[OBJECT];
        }




        const oldParent = thatdata.props["Parent"]
        // Remove from old parent's children
        if (oldParent && window.GAMEMODEL[oldParent]) {
          const siblings = window.GAMEMODEL[oldParent].children;
          const index = siblings.indexOf(OBJECT);
          if (index !== -1) {
            siblings.splice(index, 1);
          }
        }
        UpdateOBJ_asrendered(oldParent)


        delete window.GAMEMODEL[OBJECT]

        if (!not_main) {
          update_explorer()
          update_properties_tab(selectedNode.id)

        }

        window.IS_DIRTY = true
      }
      window.handle_delete_obj = handle_delete_obj


      window.materialCache = {};

      function make_vector3(x = 0, y = 0, z = 0) {
        return { x, y, z };
      }

      function make_vector2(x = 0, y = 0) {
        return { x, y };
      }

      function make_color3(r = 255, g = 255, b = 255) {
        return { r, g, b };
      }

      function make_cframe(
        px = 0, py = 0, pz = 0,
        rx = 0, ry = 0, rz = 0
      ) {
        return {
          position: { x: px, y: py, z: pz },
          rotation: { x: rx, y: ry, z: rz }
        };
      }

      window.make_vector3 = make_vector3
      window.make_vector2 = make_vector2
      window.make_color3 = make_color3
      window.make_cframe = make_cframe

      function escapeHTML(str) {
        return str.toString()
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }


      window.CLASS_Services = [
        "Workspace",
        "Players",
        "ReplicatedStorage",
        "Lighting",
        "ServerScripts",
        "ClientScripts",
      ]


      async function loadProps() {
        window.all_props_for_classes = (await (await fetch("/all_props_for_classes.json")).json());
        window.prop_types = (await (await fetch("/prop_types.json")).json());
        window.prop_default = (await (await fetch("/prop_default.json")).json());
      }



      window.props_readonly = [
        "ClassName",
      ]

      const Source_DEFAULT = `{"blocks":{"languageVersion":0,"blocks":[{"type":"event_start","id":"Ap[Aw04#fc@Tb2_=do_l","x":210,"y":96,"next":{"block":{"type":"print","id":"uGH}V%cw4ac|.8NM7l)R","inputs":{"TEXT":{"block":{"type":"type_string","id":"s:(Gd9B|y?mI~ClMJh)1","fields":{"TEXT":"Hello World"}}}}}}}]}}`
      window.selectedNode = null

      function createInstance(props) {
        const instanceID = crypto.randomUUID()
        const parentID = props["Parent"]

        if (parentID) {
          window.GAMEMODEL[parentID]["children"].push(instanceID)
        }

        for (const i of all_props_for_classes[props.ClassName]) {
          const defaultPROP = window.prop_default[i]


          if (props[i] == undefined) {
            const pt = prop_types[i]
            if (pt == "String") {
              if ((i) == "Source") {
                props[i] = Source_DEFAULT
              } else {
                props[i] = ""
              }
            } else if (pt == "Number") {
              props[i] = defaultPROP || 0
            } else if (pt == "Object") {
              props[i] = defaultPROP || null
            } else if (pt == "Vector3") {
              props[i] = defaultPROP || make_vector3()
            } else if (pt == "Color3") {
              props[i] = defaultPROP || make_color3()
            } else if (pt == "Vector2") {
              props[i] = defaultPROP || make_vector2()
            } else if (pt == "Bool") {
              props[i] = defaultPROP || true
            } else if (pt == "CFrame") {
              props[i] = defaultPROP || make_cframe()
            }
          }
        }

        window.GAMEMODEL[instanceID] = {
          children: [],
          props: props,
        }
        window.IS_DIRTY = true
        return instanceID
      }

      window.createInstance = createInstance



function destroyThreeCanvas() {
  // stop render loop first (IMPORTANT)
  if (window.isRunning !== undefined) {
    window.isRunning = false;
  }

  // dispose scene
  if (window.scene) {
    window.scene.traverse((obj) => {
      if (obj.geometry) obj.geometry.dispose();

      if (obj.material) {
        const materials = Array.isArray(obj.material)
          ? obj.material
          : [obj.material];

        for (const mat of materials) {
          for (const key in mat) {
            const v = mat[key];
            if (v && v.isTexture) v.dispose();
          }
          mat.dispose();
        }
      }
    });

    window.scene.clear();
    window.scene = null;
  }

  // dispose renderer
  if (window.renderer) {
    window.renderer.dispose();

    // remove canvas from DOM
    if (window.renderer.domElement?.parentNode) {
      window.renderer.domElement.parentNode.removeChild(
        window.renderer.domElement
      );
    }

    window.renderer = null;
  }

  // remove stats UI if exists
  if (window.stats?.dom?.parentNode) {
    window.stats.dom.parentNode.removeChild(window.stats.dom);
    window.stats = null;
  }

  // clear caches
  window.ID_TO_MESH = {};
  window.DECAL_FOR_PART_ID = {};
  window.materialCache = {};

  // clear container leftovers (optional safety)
  const container = document.getElementById("DISPLAY3dREAL");
  if (container) {
    container.innerHTML = "";
  }

  console.log("Three.js fully destroyed (scene + canvas + renderer)");
}



      function createNode(id) {
        const objectData = window.GAMEMODEL[id];
        const props = objectData.props;

        const node = document.createElement("div");
        node.className = "node";
        node.dataset.id = id;

        node.innerHTML = `
        <div class="mainnode"> 
      <img class="iconimage whiteimg openclose nochildren" src="/closed.svg">
      <div class="nodeselect">


      <img class="iconimage whiteimg" src="/exicons/${escapeHTML(props.ClassName)}.svg">

      <span>${escapeHTML(props.Name)}</span>

      </div>

      </div>

      <div class="outchilds">
        <div class="spacer"></div>
        <div class="children"></div>

      </div>
    `;

        const isOpen = openState[id] ?? false;

        if (isOpen) {
          node.querySelector(".children").classList.add("openchildren");
          node.querySelector(".openclose").src = "/open.svg";
        } else {
          node.querySelector(".children").classList.remove("openchildren");
          node.querySelector(".openclose").src = "/closed.svg";
        }

        if (selectedNode) {
          if (selectedNode["id"] == id) {
            const mainnode = node.querySelector(".mainnode")
            selectedNode = {
              dom: mainnode,
              id: id
            };
            mainnode.classList.add("selected")
          }
        }


        return node;
      }



      function update_explorer() {
        const extree = document.getElementById("explorerTree");
        extree.innerHTML = "";
        const nodes = {};

        for (const id of Object.keys(window.GAMEMODEL)) {
          nodes[id] = createNode(id);
        }
        for (const id of Object.keys(window.GAMEMODEL)) {
          const props = window.GAMEMODEL[id].props;
          const parentId = props.Parent;

          const node = nodes[id];

    
          if (parentId && (parentId != GAME_MODEL_ID)) {

            if (GAMEMODEL[parentId]) {
                            nodes[parentId]
                .querySelector(".children")
                .appendChild(node);

              nodes[parentId].querySelector(".openclose").classList.remove("nochildren");
            }

            } else {
              if (parentId) {
                extree.appendChild(node);
              }

            }
          




          const mainnode = node.querySelector(".mainnode")
          const openclose = node.querySelector(".openclose")
          const nodeselect = node.querySelector(".nodeselect")

          openclose.onclick = function () {
            openState[node.dataset.id] = !openState[node.dataset.id];

            const isOpen = openState[node.dataset.id];

            if (isOpen) {
              node.querySelector(".children").classList.add("openchildren");
              openclose.src = "/open.svg";
            } else {
              node.querySelector(".children").classList.remove("openchildren");
              openclose.src = "/closed.svg";
            }
          };


          nodeselect.ondblclick = function () {
            if (props["Source"] == undefined) {
              return
            }

            console.log("double clicked");



            let exists = opentabs[id]


            if (exists == undefined) {

            const newIFRAME = document.createElement("iframe");
            newIFRAME.src = `/scripting?forid=${id}`;

            newIFRAME.style.width = "100%";
            newIFRAME.style.height = "100%";
            newIFRAME.style.border = "none";
            newIFRAME.style.display = "block";

            SCRIPTINGiframes.set(id, newIFRAME)

            const currentsource = window.GAMEMODEL[id].props["Source"]


            document.getElementById("DISPLAY3dREAL").appendChild(newIFRAME);

              // IMPORTANT: pass the CLONE, not the original
              const scripttab = createTAB(
                props.Name,
                `/exicons/${props.ClassName}.svg`,
                newIFRAME,   // 🔥 FIXED HERE
                false,
                id
              );

              newIFRAME.onload = () => {

                const parsed = JSON.parse(currentsource)

                console.log(parsed)

                newIFRAME.contentWindow.postMessage(
                  {
                    type: "LOAD_BLOCKS",
                    id: id,
                    data: parsed
                  },
                  "*"
                );
              };
            }


             openTAB(id);

            
          };

          nodeselect.onclick = function () {
            if (window.obj_prop_changing) {

              let propname = window.obj_prop_changing.name




              if (propname == "Parent") {
                handle_parent_change(window.obj_prop_changing.ID, id)
                //open the new parent
                openState[id] = true

              } else {
                window.GAMEMODEL[window.obj_prop_changing.ID].props[propname] = id
              }



              update_properties_tab(selectedNode.id)
              update_explorer()

              UpdateOBJ_asrendered(selectedNode.id)

              document.body.classList.remove("pickmode");
              window.obj_prop_changing = false
              return
            }


            if (selectedNode) {
              selectedNode.dom.classList.remove("selected")
              update_properties_tab(selectedNode)
            }


            selectedNode = {
              dom: mainnode,
              id: node.dataset.id
            };

            mainnode.classList.add("selected")

            update_properties_tab(selectedNode.id)


          };


        }
      }

      window.update_explorer = update_explorer

      let openState = {}; // id -> true/false




      //blockly msgs

      window.addEventListener("message", (event) => {
        if (!event.data || event.data.type === "BLOCKLY_TEST") {

          const blockID = event.data.blockid
          if (!blockID) {
            return
          }
          const scriptid = event.data.scriptid
          if (!scriptid) {
              return
            }

          const sourceSTR = event.data.data

          const iframe = SCRIPTINGiframes.get(scriptid)
          if (!iframe) {
            return
          }




          const CLONEDGAME = structuredClone(window.GAMEMODEL)
          const ScriptName = CLONEDGAME[scriptid]["props"]["Name"]

          window.testrun(CLONEDGAME, sourceSTR, "studio", ScriptName, scriptid, blockID, iframe)

          return
        }




        if (!event.data || event.data.type !== "BLOCKLY_UPDATE") return;

        const blocksJSON = event.data.data
        const scriptID = event.data.forid

        const sourceSTR = JSON.stringify(blocksJSON)

        if (window.GAMEMODEL[scriptID]) {
          window.GAMEMODEL[scriptID].props["Source"] = sourceSTR
          window.IS_DIRTY = true

        } else {
          if (!window.GAMEMODEL[scriptID]) {
            let tabID = scriptID
            const [tab, dom] = opentabs[tabID];

            tab.remove();
            dom.remove();
            delete opentabs[tabID];

            // remove from history
            tabHistory = tabHistory.filter(id => id !== tabID);

            // open last tab
            const last = tabHistory[0];
            if (last && opentabs[last]) {
              openTAB(last);
            }
          }
        }







      });

      async function init() {
        await loadProps();

        load_world()
      }

      init();

      


    </script>
  </div>

</body>


