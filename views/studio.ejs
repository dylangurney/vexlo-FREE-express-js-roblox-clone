        <script>
          const log = document.getElementById("outputLog");
          let start = Date.now()
          function getServerTimeNow() {
            return Date.now() - start
          }

          function COOLoutput(type, text, Context = "", ScriptName = "") {

            const line = document.createElement("div");
            line.className = "log-line";

            const code = document.createElement("code");

            let madetext =
              `${getServerTimeNow()} ${text} ${Context} ${ScriptName}`.trim();

            code.textContent = madetext;

            if (type === 1) {
              code.style.color = "orange";
            } else if (type === 2) {
              code.style.color = "red";
            } else {
              code.style.color = "white";
            }

            line.appendChild(code);

            // 👇 insert at TOP instead of bottom
            log.prepend(line);

            // 👇 enforce max 20 lines
            while (log.children.length > 20) {
              log.removeChild(log.lastChild);
            }
          }

window.addEventListener("message", (event) => {
    if (event.data?.type === "COOLOUTPUT") {
        const { level, text, context, script } = event.data;

        COOLoutput(level, text, context, script);
    }
});
        </script>
