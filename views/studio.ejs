      function openTAB(tabID) {
        for (const i of Object.keys(opentabs)) {
          opentabs[i][1].style.display = "none";
          opentabs[i][0].classList.remove("selected");
        }

        // remove if already in history (avoid duplicates)
        tabHistory = tabHistory.filter(id => id !== tabID);

        // push to front (most recent)
        tabHistory.unshift(tabID);

        opentabs[tabID][1].style.display = "";
        opentabs[tabID][0].classList.add("selected");
      }

      window.openTAB = openTAB

      function createTAB(tabName, tabicon, VISIBLEDOM, noclose, tabID) {
        if (opentabs[tabID]) {
          //already exists return tab
          return tabID
        }


        const tab = document.createElement("div");
        tab.className = "tab";
        tab.dataset.id = tabID;

        VISIBLEDOM.style.display = "none";

        tab.innerHTML = `
        <img class="iconimage whiteimg" src="${tabicon}">
        <span>${tabName}</span>
        ${noclose ? "" : `<button class="tab-close">×</button>`}
      `;

        document.getElementById("tabs").appendChild(tab);

        opentabs[tabID] = [tab, VISIBLEDOM, noclose];

        // only attach close if allowed
        if (!noclose) {
          const closeBtn = tab.querySelector(".tab-close");

          closeBtn.onclick = (e) => {
            e.stopPropagation();

            const [tab, dom] = opentabs[tabID];

            tab.remove();
            dom.remove();
            delete opentabs[tabID];

            // remove from history
            tabHistory = tabHistory.filter(id => id !== tabID);

            // open last tab
            const last = tabHistory[0];
            if (last && opentabs[last]) {
              openTAB(last);
            }
          };
        }

        tab.onclick = (e) => {
          e.stopPropagation();
          openTAB(tabID);
        };

        return tabID;
      }

