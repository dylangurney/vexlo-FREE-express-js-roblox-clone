            return;
          }

          const buffer = await r.arrayBuffer();

          await LOADVEXL_FROM_ARRAY_BUFFER(buffer);

          console.log("Default game loaded");
        } catch (err) {
          console.error("Error loading default VEXL:", err);
        }
