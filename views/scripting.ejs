function buildBlocklyBlocks() {
  const defs = [];

  for (const cat of BLOCKS) {
    for (const b of cat.blocks) {

      const args0 = (b.args || []).map((arg) => {

        // STRING INPUT (your system)
        if (typeof arg === "object" && arg.field) {
          return {
            type: "field_input",
            name: arg.field,
            text: arg.default || ""
          };
        }

        // VARIABLE INPUT (NEW FIX)
        if (typeof arg === "object" && arg.variable) {
          return {
            type: "field_variable",
            name: arg.name,
            variable: arg.variable
          };
        }

        // VALUE SOCKET INPUT (FIXED)
        return {
          type: "input_value",
          name: arg
        };
      });

defs.push({
  type: b.type,
  message0: b.message,
  args0,
  colour: cat.colour,

  output:
  b.output !== undefined
    ? b.output
    : (b.kind === "value" ? null : undefined),

  // 🚨 IMPORTANT FIX
  previousStatement: b.kind === "statement" ? null : undefined,
  nextStatement:
    b.kind === "statement" || b.kind === "hat" ? null : undefined,


  hat: b.kind === "hat" ? "cap" : undefined
});
    }
  }

  Blockly.defineBlocksWithJsonArray(defs);
}

