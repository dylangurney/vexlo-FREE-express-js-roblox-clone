function createBlock(type) {
  const block = document.createElement("block");
  block.setAttribute("type", type);
  return block;
}
function buildToolboxXML() {
  const xml = document.createElement("xml");
  xml.id = "toolbox";

  for (const cat of BLOCKS) {
    const category = document.createElement("category");
    category.setAttribute("name", cat.category);
    category.setAttribute("colour", cat.colour);

    for (const b of cat.blocks) {
      const block = document.createElement("block");
      block.setAttribute("type", b.type);
      category.appendChild(block);
    }

    xml.appendChild(category);
  }

const controlCat = document.createElement("category");
controlCat.setAttribute("name", "Control");
controlCat.setAttribute("colour", "#FFAB19");

controlCat.appendChild(createBlock("controls_if"));
controlCat.appendChild(createBlock("controls_repeat_ext"));
controlCat.appendChild(createBlock("controls_whileUntil"));
//controlCat.appendChild(createBlock("controls_flow_statements")); // break/continue

xml.appendChild(controlCat);

  const varCat = document.createElement("category");
  varCat.setAttribute("name", "Assignments");
  varCat.setAttribute("colour", "#b5631b");
varCat.appendChild(createBlock("var_set"));
varCat.appendChild(createBlock("var_change"));
varCat.appendChild(createBlock("var_get"));

varCat.appendChild(createBlock("var_local_set"));
varCat.appendChild(createBlock("var_local_change"));
varCat.appendChild(createBlock("var_local_get"));

xml.appendChild(varCat);


  return xml;
}

buildBlocklyBlocks();
const DarkTheme = Blockly.Theme.defineTheme("dark_custom", {
  base: Blockly.Themes.Classic,

  blockStyles: {
    math_blocks: {
      colourPrimary: "#4CAF50",
      colourSecondary: "#3E8E41",
      colourTertiary: "#2E6B30"
    },
    string_blocks: {
      colourPrimary: "#9C27B0",
      colourSecondary: "#7B1FA2",
      colourTertiary: "#5E1380"
    }
  },

  categoryStyles: {
    math_category: { colour: "#4CAF50" },
    string_category: { colour: "#9C27B0" }
  },

  componentStyles: {
    workspaceBackgroundColour: "#181818",
    toolboxBackgroundColour: "#202020",
    flyoutBackgroundColour: "#2a2a2a",
    toolboxForegroundColour: "#fff",
    scrollbarColour: "#555",
    cursorColour: "#fff"
  },

  fontStyle: {
    family: "Segoe UI",
    weight: "500",
    size: 12
  }
});

const workspace = Blockly.inject("blocklyDiv", {
  toolbox: buildToolboxXML(),
  theme: DarkTheme,
  scrollbars: true,
  zoom: { controls: true },
  variables: true,
  variableCategory: "Variables",
  renderer: "zelos",
});
const urlParams = new URLSearchParams(window.location.search);
const forid = urlParams.get("forid");

let lastState = null;

setInterval(() => {
    const state = Blockly.serialization.workspaces.save(workspace);

    // 🔥 1. ignore empty workspace
    const isEmpty =
        !state ||
        (typeof state === "object" && Object.keys(state).length === 0);

    if (isEmpty) return;

    // 🔥 2. ignore unchanged state
    const serialized = JSON.stringify(state);

    if (serialized === lastState) return;

    lastState = serialized;

    window.parent.postMessage(
        {
            type: "BLOCKLY_UPDATE",
            forid: forid,
            data: state
        },
        "*"
    );
}, 100);


window.addEventListener("message", (event) => {
  if (!event.data || event.data.type !== "LOAD_BLOCKS") return;

  console.log("Received ID:", event.data.id);
  console.log("Received blocks:", event.data.data);

  Blockly.serialization.workspaces.load(event.data.data, workspace);
});

workspace.addChangeListener((event) => {
    if (event.type !== Blockly.Events.CLICK) return;
    const state = Blockly.serialization.workspaces.save(workspace);
    const serialized = JSON.stringify(state);

    window.parent.postMessage(
        {
            type: "BLOCKLY_TEST",
            blockid: event.blockId,
            scriptid: forid,
            data: serialized
        },
        "*"
    );

});

    </script>
</body>
</html>