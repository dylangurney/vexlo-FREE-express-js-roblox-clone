    <script>
      window.PLAYER_LIST = new Map();

function updatePlayerList() {
  const container = document.getElementById("player-list");

  container.innerHTML = `<div class="player-header">Players</div>`;

  const players = [...window.PLAYER_LIST.entries()]
    .sort((a, b) => {
      const nameA = GAMEMODEL[a[0]]?.props?.Name || "";
      const nameB = GAMEMODEL[b[0]]?.props?.Name || "";
      return nameA.localeCompare(nameB);
    });

  for (const [id] of players) {
    const name = GAMEMODEL[id]?.props?.Name || "Unknown";

    const div = document.createElement("div");
    div.className = "player-entry";
    div.textContent = name;

    container.appendChild(div);
  }
}
function addPlayer(id, data) {
  window.PLAYER_LIST.set(id, data);
  updatePlayerList();
}
function removePlayer(id) {
  window.PLAYER_LIST.delete(id);
  updatePlayerList();
}
window.addPlayer = addPlayer
window.removePlayer = removePlayer

      const input = document.getElementById("chat-input");
      window.activeBubbles = []

const BUBBLE_BASE_OFFSET = 100; // default lift above head
const BUBBLE_STACK_SPACING = 35;

function rebuildBubbleStack(plrI) {
  const bubbles = window.activeBubbles.filter(b => b.plrI === plrI);

  // oldest on top, newest at bottom
  bubbles.forEach((b, i) => {
    const indexFromBottom = (bubbles.length - 1) - i;

    b.offsetY =
      BUBBLE_BASE_OFFSET +
      (indexFromBottom * BUBBLE_STACK_SPACING);
  });
}

function createChatBubble(plrI, text) {
  const obj = getcharfromplr(plrI);
  if (!obj) return;

  const screen = worldToScreen(obj);
  const x = screen.x;
  const y = screen.y - BUBBLE_BASE_OFFSET;

  const div = document.createElement("div");
  div.className = "chat-bubble";
  div.textContent = text;

  div.style.transform = `translate(${x}px, ${y}px)`;

  document.body.appendChild(div);

  window.activeBubbles.push({
    plrI,
    object: obj,
    dom: div,
    x: 0,
    y: 0,
    offsetY: 0,
    time: Date.now()
  });

  rebuildBubbleStack(plrI);

  // auto remove after 5s
  setTimeout(() => {
    div.remove();
    window.activeBubbles =
      window.activeBubbles.filter(b => b.dom !== div);
  }, 5000);
}



function getnamefromplr(plr) {
  console.log(GAMEMODEL, plr)
  return GAMEMODEL[plr]?.props?.Name || "???";
}

function getcharfromplr(plr) {
  const model = GAMEMODEL[plr];
  if (!model) return false;

  const char = model.props?.Character;
  if (!char) return false;

  return char;
}



function addChatMessage(plrI, text) {
  createChatBubble(plrI, text)
  const username = getnamefromplr(plrI)
  const log = document.getElementById("chat-log");

  const div = document.createElement("div");
  div.className = "chatmsg"
  div.textContent = `${username}: ${text}`;

  log.appendChild(div);
  log.scrollTop = log.scrollHeight;

  // remove after 30 seconds
  setTimeout(() => {
    div.remove();
  }, 30000);
}

window.addChatMessage = addChatMessage

let typingTimeout = null;
let isTyping = false;

function startTyping() {
  if (isTyping) return;

  isTyping = true;

  window.VEXL_WS.send(JSON.stringify({
    type: "typing",
    data: { state: true }
  }));
}



function stopTyping() {
  if (!isTyping) return;

  isTyping = false;

  window.VEXL_WS.send(JSON.stringify({
    type: "typing",
    data: { state: false }
  }));
}

input.addEventListener("input", () => {
  startTyping();

  clearTimeout(typingTimeout);
  typingTimeout = setTimeout(() => {
    stopTyping();
  }, 1000); // stops typing after 1s idle
});

input.addEventListener("keydown", (e) => {
  if (e.key === "Enter") {
    const msg = input.value;
    input.value = "";

    window.VEXL_WS.send(JSON.stringify({
        type: "send_chat",
        data: { msg }
    }));

    stopTyping();
    input.blur()

  }
});
document.addEventListener("keydown", (e) => {
  // ignore if already typing in input
  if (document.activeElement === input) return;

  // ignore modifiers
  if (e.ctrlKey || e.altKey || e.metaKey) return;

  if (e.key === "/") {
    e.preventDefault();

    input.focus();
    input.value = "";
  }
});

function istyping() {
  return document.activeElement === input;
}
window.istyping = istyping

    </script>
