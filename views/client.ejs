     <style>
      .player-header {
  font-size: 12px;
  font-weight: bold;
  opacity: 0.8;

  padding: 4px 6px;
  margin-bottom: 4px;

  border-bottom: 1px solid rgba(255,255,255,0.1);
}
#player-list {
  position: absolute;
  top: 20px;
  right: 20px;
  z-index: 10000;

  width: 200px;
  max-height: 320px;
  overflow-y: auto;

  padding: 6px;

  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);

