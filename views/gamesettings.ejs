<html lang="en">
<head>
    <%- include("partials/head") %>
    <title>Game Settings</title>
    <%- include("partials/embeds") %>

    <style>
        .settings-container {
            max-width: 600px;
            margin: 30px auto;
            padding: 20px;
            color: white;
            gap: 10px;
            display: flex;
            flex-direction: column;
        }

        .page-title {
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 20px;
        }

        .setting-card {
            background: #1e1e1e;
            border-radius: 12px;
            padding: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .setting-label {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .setting-title {
            font-size: 14px;
            font-weight: 600;
        }

        .setting-desc {
            font-size: 12px;
            color: #aaa;
        }

        /* SWITCH */
        .switch {
            position: relative;
            width: 46px;
            height: 26px;
        }

        .switch input {
            display: none;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: #444;
            border-radius: 999px;
            transition: 0.2s;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 20px;
            width: 20px;
            left: 3px;
            top: 3px;
            background-color: white;
            border-radius: 50%;
            transition: 0.2s;
        }

        input:checked + .slider {
            background-color: #4caf50;
        }

        input:checked + .slider:before {
            transform: translateX(20px);
        }

        .save-btn {
            margin-top: 20px;
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 10px;
            background: #4caf50;
            color: white;
            font-weight: 600;
            cursor: pointer;
        }

        .save-btn:hover {
            background: #43a047;
        }

        .game-thumb {
            width: 200px;
            height: 200px;
        }
    </style>
</head>

<body>
<div class="layout">

    <%- include("partials/navbar") %>

    <div class="main">
        <%- include("partials/sidenav") %>

        <div class="content">

            <div class="settings-container">
                <div class="page-title"><%= game.name %> Settings</div>
                <img 
                    class="game-thumb" 
                    src="/gamethumbnails/<%= game.thumbnail %>"
                    alt="thumbnail"
                >

                <div class="setting-card">
                <div class="setting-label">
                    <div class="setting-title">Thumbnail</div>
                    <div class="setting-desc">Upload a game thumbnail image</div>

                    <input
                    type="file"
                    id="thumbnailInput"
                    accept="image/*"
                    style="margin-top:10px"
                    />
                </div>
                </div>

                <div class="setting-card">

                    <div class="setting-label">
                        <div class="setting-title">Name</div>
                        <input
                            id="gameNameInput"
                            type="text"
                            value="<%= game.name %>"
                            style="
                                margin-top: 10px;
                                padding: 8px;
                                border-radius: 8px;
                                border: none;
                                outline: none;
                                background: #2a2a2a;
                                color: white;
                            "
                        />
                    </div>
                </div>

                <div class="setting-card">
                    <div class="setting-label">
                        <div class="setting-title">Description</div>
                        <div class="setting-desc">
                            Tell players what your game is about
                        </div>

                        <textarea
                            id="gameDescriptionInput"
                            style="
                                margin-top: 10px;
                                padding: 8px;
                                border-radius: 8px;
                                border: none;
                                outline: none;
                                background: #2a2a2a;
                                color: white;
                                width: 100%;
                                min-height: 80px;
                                resize: vertical;
                            "
                        ><%= game.description || 'No description yet.' %></textarea>
                    </div>
                </div>

                <div class="setting-card">
                    <div class="setting-label">
                        <div class="setting-title">Public Game</div>
                        <div class="setting-desc">
                            Allow anyone to discover and join this game
                        </div>
                    </div>

                    <label class="switch">
                    <input 
                        type="checkbox" 
                        id="publicToggle"
                        <%= game.is_public ? "checked" : "" %>
                    >
                    <span class="slider"></span>
                    </label>
                </div>

                <button class="save-btn" onclick="saveSettings()">
                    Save Changes
                </button>

                <a href="/game/<%= game?.id %>">
                    <button class="back-btn"">
                        Back to game
                    </button>
                </a>

            </div>

        </div>

    </div>

</div>

<script>
const gameId = "<%= game?.id || '' %>";

let editedThumb = false

const X = 128
const Y = 128

function resize(file) {
  return new Promise((resolve) => {
    const img = new Image();
    const reader = new FileReader();

    reader.onload = (e) => {
      img.src = e.target.result;
    };

    img.onload = () => {
      const canvas = document.createElement("canvas");
      canvas.width = X;
      canvas.height = Y;

      const ctx = canvas.getContext("2d");

      // STRETCH (no aspect ratio)
      ctx.drawImage(
        img,
        0, 0, img.width, img.height,
        0, 0, X, Y
      );

      canvas.toBlob((blob) => {
        resolve(blob);
      }, "image/png");
    };

    reader.readAsDataURL(file);
  });
}

function blobToBase64(blob) {
  return new Promise((resolve) => {
    const reader = new FileReader();
    reader.onloadend = () => resolve(reader.result); // base64 string
    reader.readAsDataURL(blob);
  });
}

document.getElementById("thumbnailInput").onchange = async (e) => {
  const file = e.target.files[0];
  if (!file) return;
  let scaledfile = await resize(file)
  editedThumb = scaledfile

  const img = document.querySelector(".game-thumb");
  img.src = URL.createObjectURL(scaledfile);
};


async function saveSettings() {
    const isPublic = document.getElementById("publicToggle").checked;
    const name = document.getElementById("gameNameInput").value;
    const description = document.getElementById("gameDescriptionInput").value;

    const formData = new FormData();

    formData.append("is_public", isPublic);
    formData.append("name", name);
    formData.append("description", description);

    if (editedThumb) {
        formData.append("thumbnail", editedThumb, "thumbnail.png");
    }

    await fetch(`/api/games/${gameId}/settings`, {
        method: "POST",
        body: formData
    });

    banneralert("Saved");
}
</script>

</body>
</html>